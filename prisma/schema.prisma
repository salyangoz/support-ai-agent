generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  apiKey    String   @unique @map("api_key") @db.VarChar(128)
  settings  Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  apps              App[]
  customers         Customer[]
  tickets           Ticket[]
  messages          Message[]
  knowledgeArticles KnowledgeArticle[]
  drafts            Draft[]

  @@map("tenants")
}

model App {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @map("tenant_id")
  code          String   @db.VarChar(30)
  type          String   @db.VarChar(20)
  role          String   @db.VarChar(15)
  name          String?  @db.VarChar(100)
  credentials   Json     @default("{}")
  webhookSecret String?  @map("webhook_secret") @db.VarChar(255)
  config        Json     @default("{}")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  inputTickets  Ticket[] @relation("InputApp")
  outputTickets Ticket[] @relation("OutputApp")

  @@index([tenantId])
  @@index([tenantId, type, role])
  @@index([tenantId, code])
  @@index([tenantId, isActive])
  @@map("apps")
}

model Customer {
  id         Int      @id @default(autoincrement())
  tenantId   Int      @map("tenant_id")
  externalId String?  @map("external_id") @db.VarChar(128)
  email      String?  @db.VarChar(255)
  name       String?  @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  tickets Ticket[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, externalId])
  @@map("customers")
}

model Ticket {
  id                Int       @id @default(autoincrement())
  tenantId          Int       @map("tenant_id")
  customerId        Int?      @map("customer_id")
  inputAppId        Int?      @map("input_app_id")
  outputAppId       Int?      @map("output_app_id")
  externalId        String    @map("external_id") @db.VarChar(128)
  state             String    @default("open") @db.VarChar(20)
  subject           String?
  initialBody       String?   @map("initial_body")
  language          String?   @db.VarChar(10)
  assigneeId        String?   @map("assignee_id") @db.VarChar(64)
  externalCreatedAt DateTime? @map("external_created_at") @db.Timestamptz
  externalUpdatedAt DateTime? @map("external_updated_at") @db.Timestamptz
  syncedAt          DateTime  @default(now()) @map("synced_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  customer  Customer? @relation(fields: [customerId], references: [id])
  inputApp  App?      @relation("InputApp", fields: [inputAppId], references: [id])
  outputApp App?      @relation("OutputApp", fields: [outputAppId], references: [id])
  messages  Message[]
  drafts    Draft[]

  @@unique([tenantId, inputAppId, externalId])
  @@index([tenantId, state])
  @@index([customerId])
  @@index([inputAppId])
  @@index([outputAppId])
  @@map("tickets")
}

model Message {
  id                Int                          @id @default(autoincrement())
  ticketId          Int                          @map("ticket_id")
  tenantId          Int                          @map("tenant_id")
  externalId        String                       @map("external_id") @db.VarChar(128)
  authorRole        String                       @map("author_role") @db.VarChar(20)
  authorId          String?                      @map("author_id") @db.VarChar(64)
  authorName        String?                      @map("author_name") @db.VarChar(255)
  body              String?
  embedding         Unsupported("vector(1536)")?
  externalCreatedAt DateTime?                    @map("external_created_at") @db.Timestamptz
  createdAt         DateTime                     @default(now()) @map("created_at") @db.Timestamptz

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([ticketId, externalId])
  @@index([ticketId])
  @@index([tenantId])
  @@map("messages")
}

model KnowledgeArticle {
  id        Int                          @id @default(autoincrement())
  tenantId  Int                          @map("tenant_id")
  title     String                       @db.VarChar(500)
  content   String
  category  String?                      @db.VarChar(100)
  language  String?                      @default("tr") @db.VarChar(10)
  embedding Unsupported("vector(1536)")?
  isActive  Boolean                      @default(true) @map("is_active")
  createdAt DateTime                     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, isActive])
  @@map("knowledge_articles")
}

model Draft {
  id            Int       @id @default(autoincrement())
  ticketId      Int       @map("ticket_id")
  tenantId      Int       @map("tenant_id")
  promptContext String?   @map("prompt_context")
  draftResponse String    @map("draft_response")
  aiModel       String?   @map("ai_model") @db.VarChar(100)
  aiTokensUsed  Int?      @map("ai_tokens_used")
  status        String    @default("pending") @db.VarChar(20)
  reviewedBy    String?   @map("reviewed_by") @db.VarChar(64)
  reviewedAt    DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([ticketId])
  @@index([tenantId, status])
  @@map("drafts")
}
